# Bitbucket Pipelines for {{ model.project_name }}
# Generated by ai-infra

image: python:3.11-slim

definitions:
  services:
    docker:
      memory: 2048

pipelines:
  default:
{% if cicd.lint %}
    - step:
        name: Lint
        script:
          - echo "Add your lint command here"
{% endif %}

{% if cicd.run_tests %}
    - step:
        name: Test
        script:
          - echo "Add your test command here"
{% endif %}

{% for svc in app_services %}
    - step:
        name: Build {{ svc.name }}
        services:
          - docker
        script:
          - docker login -u $DOCKER_USERNAME -p $DOCKER_PASSWORD {{ cicd.registry }}
          - docker build -t {{ cicd.registry }}/{{ model.project_name }}/{{ svc.name }}:$BITBUCKET_COMMIT -f Dockerfile.{{ svc.name }} .
          - docker push {{ cicd.registry }}/{{ model.project_name }}/{{ svc.name }}:$BITBUCKET_COMMIT
{% endfor %}

{% if cicd.auto_deploy %}
    - step:
        name: Deploy
        deployment: production
        script:
          - pipe: atlassian/kubectl-run:3.2.0
            variables:
              KUBE_CONFIG: $KUBE_CONFIG
              KUBECTL_COMMAND: "apply"
              RESOURCE_PATH: "k8s/"
{% endif %}

  branches:
    main:
{% for svc in app_services %}
      - step:
          name: Build {{ svc.name }}
          services:
            - docker
          script:
            - docker login -u $DOCKER_USERNAME -p $DOCKER_PASSWORD {{ cicd.registry }}
            - docker build -t {{ cicd.registry }}/{{ model.project_name }}/{{ svc.name }}:$BITBUCKET_COMMIT -f Dockerfile.{{ svc.name }} .
            - docker push {{ cicd.registry }}/{{ model.project_name }}/{{ svc.name }}:$BITBUCKET_COMMIT
{% endfor %}
