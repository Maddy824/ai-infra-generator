# CircleCI configuration for {{ model.project_name }}
# Generated by ai-infra

version: 2.1

orbs:
  docker: circleci/docker@2.4

executors:
  default:
    docker:
      - image: cimg/python:3.11

jobs:
{% if cicd.lint %}
  lint:
    executor: default
    steps:
      - checkout
      - run:
          name: Lint
          command: echo "Add your lint command here"
{% endif %}

{% if cicd.run_tests %}
  test:
    executor: default
    steps:
      - checkout
      - run:
          name: Test
          command: echo "Add your test command here"
{% endif %}

{% for svc in app_services %}
  build-{{ svc.name }}:
    executor: default
    steps:
      - checkout
      - setup_remote_docker:
          version: 20.10.24
      - run:
          name: Build and push {{ svc.name }}
          command: |
            echo "$DOCKER_PASSWORD" | docker login -u "$DOCKER_USERNAME" --password-stdin {{ cicd.registry }}
            docker build -t {{ cicd.registry }}/{{ model.project_name }}/{{ svc.name }}:${CIRCLE_SHA1} -f Dockerfile.{{ svc.name }} .
            docker push {{ cicd.registry }}/{{ model.project_name }}/{{ svc.name }}:${CIRCLE_SHA1}
{% endfor %}

{% if cicd.auto_deploy %}
  deploy:
    docker:
      - image: bitnami/kubectl:latest
    steps:
      - checkout
      - run:
          name: Deploy to Kubernetes
          command: kubectl apply -f k8s/
{% endif %}

workflows:
  build-deploy:
    jobs:
{% if cicd.lint %}
      - lint
{% endif %}
{% if cicd.run_tests %}
      - test
{% endif %}
{% for svc in app_services %}
      - build-{{ svc.name }}:
          requires:
{% if cicd.lint %}
            - lint
{% endif %}
{% if cicd.run_tests %}
            - test
{% endif %}
{% endfor %}
{% if cicd.auto_deploy %}
      - deploy:
          requires:
{% for svc in app_services %}
            - build-{{ svc.name }}
{% endfor %}
          filters:
            branches:
              only: main
{% endif %}
