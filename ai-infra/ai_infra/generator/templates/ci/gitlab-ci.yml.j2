# GitLab CI/CD pipeline for {{ model.project_name }}
# Generated by ai-infra

stages:
  - lint
  - test
  - build
  - deploy

variables:
  REGISTRY: {{ cicd.registry }}
  IMAGE_PREFIX: {{ model.project_name }}

{% if cicd.lint %}
lint:
  stage: lint
  image: python:3.11-slim
  script:
    - echo "Add your lint command here"
{% endif %}

{% if cicd.run_tests %}
test:
  stage: test
  image: python:3.11-slim
  script:
    - echo "Add your test command here"
{% endif %}

{% for svc in app_services %}
build-{{ svc.name }}:
  stage: build
  image: docker:24
  services:
    - docker:24-dind
  variables:
    DOCKER_TLS_CERTDIR: "/certs"
  script:
    - docker login -u $CI_REGISTRY_USER -p $CI_REGISTRY_PASSWORD $CI_REGISTRY
    - docker build -t $REGISTRY/$IMAGE_PREFIX/{{ svc.name }}:$CI_COMMIT_SHA -f Dockerfile.{{ svc.name }} .
    - docker push $REGISTRY/$IMAGE_PREFIX/{{ svc.name }}:$CI_COMMIT_SHA
{% endfor %}

{% if cicd.auto_deploy %}
deploy:
  stage: deploy
  image: bitnami/kubectl:latest
  script:
    - kubectl apply -f k8s/
  only:
    - main
  environment:
    name: production
{% endif %}
