# Terraform configuration for {{ model.project_name }} on Azure AKS
# Generated by ai-infra

terraform {
  required_version = ">= 1.5"
  required_providers {
    azurerm = {
      source  = "hashicorp/azurerm"
      version = "~> 3.0"
    }
  }
}

provider "azurerm" {
  features {}
}

# --- Resource Group ---
resource "azurerm_resource_group" "main" {
  name     = "{{ model.project_name }}-rg"
  location = "{{ iac.region }}"

  tags = {
    Project   = "{{ model.project_name }}"
    ManagedBy = "ai-infra"
  }
}

# --- AKS Cluster ---
resource "azurerm_kubernetes_cluster" "main" {
  name                = "{{ iac.cluster_name or model.project_name }}"
  location            = azurerm_resource_group.main.location
  resource_group_name = azurerm_resource_group.main.name
  dns_prefix          = "{{ model.project_name }}"
  kubernetes_version  = "{{ iac.kubernetes_version }}"

  default_node_pool {
    name       = "default"
    node_count = {{ iac.node_count }}
    vm_size    = "{{ iac.node_instance_type }}"

    tags = {
      Project   = "{{ model.project_name }}"
      ManagedBy = "ai-infra"
    }
  }

  identity {
    type = "SystemAssigned"
  }

  network_profile {
    network_plugin = "azure"
    network_policy = "calico"
  }

  tags = {
    Project   = "{{ model.project_name }}"
    ManagedBy = "ai-infra"
  }
}

# --- Outputs ---
output "cluster_name" {
  value = azurerm_kubernetes_cluster.main.name
}

output "kube_config" {
  value     = azurerm_kubernetes_cluster.main.kube_config_raw
  sensitive = true
}

output "resource_group" {
  value = azurerm_resource_group.main.name
}
