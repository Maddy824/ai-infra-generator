# Terraform configuration for {{ model.project_name }} on GCP GKE
# Generated by ai-infra

terraform {
  required_version = ">= 1.5"
  required_providers {
    google = {
      source  = "hashicorp/google"
      version = "~> 5.0"
    }
  }
}

provider "google" {
  region = "{{ iac.region }}"
}

# --- GKE Cluster ---
resource "google_container_cluster" "primary" {
  name     = "{{ iac.cluster_name or model.project_name }}"
  location = "{{ iac.region }}"

  min_master_version = "{{ iac.kubernetes_version }}"

  # We manage the default node pool separately
  remove_default_node_pool = true
  initial_node_count       = 1

  network_policy {
    enabled = true
  }

  resource_labels = {
    project    = "{{ model.project_name }}"
    managed-by = "ai-infra"
  }
}

resource "google_container_node_pool" "default" {
  name       = "default-pool"
  location   = "{{ iac.region }}"
  cluster    = google_container_cluster.primary.name
  node_count = {{ iac.node_count }}

  node_config {
    machine_type = "{{ iac.node_instance_type }}"

    labels = {
      project    = "{{ model.project_name }}"
      managed-by = "ai-infra"
    }

    oauth_scopes = [
      "https://www.googleapis.com/auth/cloud-platform",
    ]
  }

  autoscaling {
    min_node_count = 1
    max_node_count = {{ iac.node_count * 2 }}
  }
}

# --- Outputs ---
output "cluster_name" {
  value = google_container_cluster.primary.name
}

output "cluster_endpoint" {
  value     = google_container_cluster.primary.endpoint
  sensitive = true
}

output "region" {
  value = "{{ iac.region }}"
}
