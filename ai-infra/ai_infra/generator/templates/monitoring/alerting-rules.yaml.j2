# Prometheus alerting rules for {{ model.project_name }}
# Generated by ai-infra
apiVersion: monitoring.coreos.com/v1
kind: PrometheusRule
metadata:
  name: {{ model.project_name }}-alerts
  labels:
    project: {{ model.project_name }}
spec:
  groups:
{% for svc in app_services %}
    - name: {{ svc.name }}.rules
      rules:
        - alert: {{ svc.name }}_HighCpuUsage
          expr: |
            rate(container_cpu_usage_seconds_total{container="{{ svc.name }}"}[5m]) * 100 > {{ thresholds.cpu_percent }}
          for: 5m
          labels:
            severity: warning
            service: {{ svc.name }}
          annotations:
            summary: "High CPU usage on {{ svc.name }}"
            description: "CPU usage is above {{ thresholds.cpu_percent }}% for more than 5 minutes."

        - alert: {{ svc.name }}_HighMemoryUsage
          expr: |
            container_memory_usage_bytes{container="{{ svc.name }}"} / container_spec_memory_limit_bytes{container="{{ svc.name }}"} * 100 > {{ thresholds.memory_percent }}
          for: 5m
          labels:
            severity: warning
            service: {{ svc.name }}
          annotations:
            summary: "High memory usage on {{ svc.name }}"
            description: "Memory usage is above {{ thresholds.memory_percent }}% for more than 5 minutes."

        - alert: {{ svc.name }}_HighErrorRate
          expr: |
            rate(http_requests_total{container="{{ svc.name }}", code=~"5.."}[5m])
            / rate(http_requests_total{container="{{ svc.name }}"}[5m]) * 100 > {{ thresholds.error_rate_5xx }}
          for: 5m
          labels:
            severity: critical
            service: {{ svc.name }}
          annotations:
            summary: "High 5xx error rate on {{ svc.name }}"
            description: "Error rate is above {{ thresholds.error_rate_5xx }}% for more than 5 minutes."

        - alert: {{ svc.name }}_HighLatency
          expr: |
            histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{container="{{ svc.name }}"}[5m])) * 1000 > {{ thresholds.p99_latency_ms }}
          for: 5m
          labels:
            severity: warning
            service: {{ svc.name }}
          annotations:
            summary: "High p99 latency on {{ svc.name }}"
            description: "p99 latency is above {{ thresholds.p99_latency_ms }}ms for more than 5 minutes."

        - alert: {{ svc.name }}_PodRestarts
          expr: |
            increase(kube_pod_container_status_restarts_total{container="{{ svc.name }}"}[1h]) > 3
          for: 10m
          labels:
            severity: warning
            service: {{ svc.name }}
          annotations:
            summary: "Frequent pod restarts for {{ svc.name }}"
            description: "Pod has restarted more than 3 times in the last hour."
{% endfor %}
