# Prometheus ServiceMonitor for {{ svc.name }}
# Generated by ai-infra
apiVersion: monitoring.coreos.com/v1
kind: ServiceMonitor
metadata:
  name: {{ svc.name }}-monitor
  labels:
    app: {{ svc.name }}
    project: {{ model.project_name }}
spec:
  selector:
    matchLabels:
      app: {{ svc.name }}
  endpoints:
    - port: metrics
      path: {{ monitoring.metrics_path }}
      interval: 30s
