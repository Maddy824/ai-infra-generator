apiVersion: autoscaling/v2
kind: HorizontalPodAutoscaler
metadata:
  name: {{ svc.name }}-hpa
  labels:
    app: {{ svc.name }}
    project: {{ model.project_name }}
spec:
  scaleTargetRef:
    apiVersion: apps/v1
    kind: Deployment
    name: {{ svc.name }}
{% if svc.sizing.scale == "prod" %}
  minReplicas: 2
  maxReplicas: 10
{% elif svc.sizing.scale == "heavy" %}
  minReplicas: 3
  maxReplicas: 20
{% endif %}
  metrics:
    - type: Resource
      resource:
        name: cpu
        target:
          type: Utilization
{% if svc.sizing.workload_type == "latency-sensitive" %}
          averageUtilization: 50
{% elif svc.sizing.workload_type == "batch" %}
          averageUtilization: 85
{% elif svc.sizing.workload_type == "background" %}
          averageUtilization: 80
{% else %}
          averageUtilization: 70
{% endif %}
